# Server Environment Variables

# Server configuration
PORT=5000
NODE_ENV=development

# API configuration
API_PREFIX=/api
API_VERSION=v1

# MongoDB connection
MONGODB_URI= mongodb://admin:secure_password@site-analyser-mongodb-1:27017/site-analyser?authSource=admin&directConnection=true
#mongodb://localhost:27017/site-analyser
MONGODB_URI_PRODUCTION=mongodb://admin:secure_password@site-analyser-mongodb-1:27017/site-analyser?authSource=admin&directConnection=true
#mongodb://username:password@db.site-analyser.com:27017/site-analyser

# JWT authentication
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# Redis cache
REDIS_HOST=site-analyser-redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=debug
LOG_FORMAT=dev

# CORS settings
CORS_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=15*60*1000
RATE_LIMIT_MAX=100

# Third-party service API keys
SHODAN_API_KEY=your_shodan_api_key
VIRUS_TOTAL_API_KEY=your_virustotal_api_key
SSL_LABS_API_KEY=your_ssllabs_api_key

# AI service integration
AI_SERVICE_URL=http://localhost:8000/api

# Email notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=security@site-analyser.com
