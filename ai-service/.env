# AI Service Environment Variables

# Application settings
APP_NAME=site-analyser-ai
APP_ENV=development
DEBUG=true
LOG_LEVEL=debug

# API settings
API_PORT=8000
API_HOST=0.0.0.0
API_PREFIX=/api
API_VERSION=v1

# Security settings
SECRET_KEY=your_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS settings
ALLOWED_ORIGINS=http://localhost:3000

# Server backend integration
SERVER_API_URL=http://localhost:5000/api
SERVER_API_KEY=your_server_api_key

# ML Model settings
MODEL_PATH=./app/models/trained
THREAT_MODEL_VERSION=v1.0.0
ANOMALY_MODEL_VERSION=v1.0.0
RISK_SCORING_MODEL_VERSION=v1.0.0

# External LLM settings
OLLAMA_API_URL=http://localhost:11434/api
OLLAMA_MODEL=llama2

# Threat intelligence API keys
VIRUSTOTAL_API_KEY=your_virustotal_api_key
SHODAN_API_KEY=your_shodan_api_key

# Redis cache (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Performance settings
WORKERS=4
WORKER_CONNECTIONS=1000
TIMEOUT=300
