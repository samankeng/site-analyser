# Common environment variables shared across all environments

# API URL - will be overridden by environment-specific files
REACT_APP_API_URL=

# Authentication
REACT_APP_AUTH_COOKIE_NAME=site_analyser_auth
REACT_APP_AUTH_TOKEN_EXPIRES=86400

# Feature flags
REACT_APP_ENABLE_AI_RECOMMENDATIONS=true
REACT_APP_ENABLE_NOTIFICATIONS=true

# Application defaults
REACT_APP_DEFAULT_THEME=light
REACT_APP_DEFAULT_LANGUAGE=en

# Timeout settings
REACT_APP_API_TIMEOUT=30000
REACT_APP_SCAN_POLL_INTERVAL=5000

# App information
REACT_APP_VERSION=$npm_package_version
